{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://jl-engine.dev/schemas/mpf/mpf-v5.json",
  "$comment": "Copyright 2026 Jaden Lindenbach (https://github.com/jaden688/JL_Engine-local). Licensed under PolyForm Noncommercial 1.0.0. See LICENSE.md.",
  "title": "Modular Personality Format v5",
  "description": "Portable, model-agnostic JSON schema for agent personalities. Supports rich personality definitions with cognitive modes, emotional dynamics, and safety boundaries.",
  "type": "object",
  "required": ["schema_version", "name", "kind"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "mpf-v5",
      "description": "MPF schema version identifier"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Agent display name"
    },
    "kind": {
      "type": "string",
      "enum": ["personality", "task_agent"],
      "description": "Agent type: personality (rich) or task_agent (lean)"
    },
    "version": {
      "type": "string",
      "description": "Agent version (semantic versioning recommended)"
    },
    "display_name": {
      "type": "string",
      "description": "Alternative display name"
    },
    "base_prompt": {
      "type": "string",
      "description": "System prompt or primary instruction"
    },
    "identity": {
      "$ref": "#/definitions/identity"
    },
    "core_identity": {
      "$ref": "#/definitions/core_identity"
    },
    "behavior": {
      "$ref": "#/definitions/behavior"
    },
    "communication_style": {
      "$ref": "#/definitions/communication_style"
    },
    "linguistic_style": {
      "$ref": "#/definitions/linguistic_style"
    },
    "safety": {
      "$ref": "#/definitions/safety"
    },
    "memory": {
      "$ref": "#/definitions/memory"
    },
    "cognitive_gears": {
      "$ref": "#/definitions/cognitive_gears"
    },
    "cognitive_modes": {
      "$ref": "#/definitions/cognitive_modes"
    },
    "gait": {
      "$ref": "#/definitions/mode_profile"
    },
    "rhythm": {
      "$ref": "#/definitions/mode_profile"
    },
    "aperture": {
      "$ref": "#/definitions/mode_profile"
    },
    "emotional_aperture": {
      "$ref": "#/definitions/emotional_aperture"
    },
    "emotion_wheel": {
      "$ref": "#/definitions/emotion_wheel"
    },
    "emotion_palette": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/emotion_palette_entry"
      },
      "description": "Discrete emotional states with temperature/top_p sampling biases"
    },
    "operational_behavioral_traits": {
      "$ref": "#/definitions/operational_behavioral_traits"
    },
    "engine_alignment": {
      "$ref": "#/definitions/loose_object",
      "description": "Runtime-specific routing and behavioral modulation parameters"
    },
    "llm_profiles": {
      "$ref": "#/definitions/llm_profiles"
    },
    "pacing_instructions": {
      "oneOf": [
        {
          "$ref": "#/definitions/string_list"
        },
        {
          "$ref": "#/definitions/loose_object"
        }
      ]
    },
    "rhythm_instructions": {
      "oneOf": [
        {
          "$ref": "#/definitions/string_list"
        },
        {
          "$ref": "#/definitions/loose_object"
        }
      ]
    },
    "output_pacing_instructions": {
      "oneOf": [
        {
          "$ref": "#/definitions/string_list"
        },
        {
          "$ref": "#/definitions/loose_object"
        }
      ]
    },
    "meta": {
      "$ref": "#/definitions/loose_object",
      "description": "Metadata, versioning, authoring info"
    }
  },
  "anyOf": [
    {
      "required": ["identity"]
    },
    {
      "required": ["core_identity"]
    }
  ],
  "definitions": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "string_list": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "loose_object": {
      "type": "object",
      "additionalProperties": true
    },
    "identity": {
      "type": "object",
      "required": ["name", "role"],
      "properties": {
        "name": {
          "$ref": "#/definitions/non_empty_string"
        },
        "role": {
          "$ref": "#/definitions/non_empty_string"
        },
        "archetype": {
          "type": "string",
          "description": "Character archetype or meta-role (e.g., 'chaotic-builder')"
        },
        "description": {
          "type": "string",
          "description": "Full personality description"
        },
        "voice": {
          "type": "string",
          "description": "Speech patterns and vocal identity"
        },
        "style": {
          "type": "string",
          "description": "Overall stylistic presentation"
        },
        "source_scenario": {
          "type": "string",
          "description": "Origin story or context"
        },
        "tags": {
          "$ref": "#/definitions/string_list"
        }
      },
      "additionalProperties": true
    },
    "core_identity": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "behavior": {
      "type": "object",
      "properties": {
        "core_directives": {
          "$ref": "#/definitions/string_list",
          "description": "Primary behavioral anchors"
        },
        "directives": {
          "$ref": "#/definitions/string_list"
        },
        "rules": {
          "$ref": "#/definitions/string_list"
        },
        "constraints": {
          "$ref": "#/definitions/string_list"
        },
        "avoidances": {
          "$ref": "#/definitions/string_list",
          "description": "Anti-patterns and things to avoid"
        },
        "boundaries": {
          "$ref": "#/definitions/string_list",
          "description": "Hard limits and constraints"
        },
        "edge_behavior": {
          "$ref": "#/definitions/loose_object",
          "description": "How to behave under pressure or uncertainty"
        },
        "tone": {
          "type": "string"
        },
        "scenario": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "communication_style": {
      "type": "object",
      "properties": {
        "voice": {
          "type": "string"
        },
        "agentlity": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "$ref": "#/definitions/loose_object"
            }
          ]
        },
        "style_notes": {
          "$ref": "#/definitions/string_list"
        }
      },
      "additionalProperties": true
    },
    "linguistic_style": {
      "type": "object",
      "properties": {
        "fluency": {
          "type": "string"
        },
        "rhythm": {
          "type": "string"
        },
        "style_tokens": {
          "$ref": "#/definitions/string_list"
        },
        "profanity_allowed": {
          "type": "boolean"
        },
        "cultural_influences": {
          "$ref": "#/definitions/string_list"
        }
      },
      "additionalProperties": true
    },
    "safety": {
      "type": "object",
      "properties": {
        "content_policies": {
          "$ref": "#/definitions/string_list",
          "description": "Content policies this agent must follow"
        },
        "refusal_directives": {
          "$ref": "#/definitions/string_list",
          "description": "Categories or requests the agent refuses"
        },
        "jailbreak_resistance": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Resistance score to prompt injection attacks"
        },
        "truthfulness_enforcement": {
          "type": "boolean",
          "description": "Must agent correct false statements or admit uncertainty?"
        },
        "harm_awareness": {
          "type": "boolean",
          "description": "Must agent consider consequences of its outputs?"
        }
      },
      "additionalProperties": true
    },
    "memory": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["ephemeral", "shortterm", "hybrid", "persistent"],
          "description": "Default memory mode"
        },
        "short_term_focus": {
          "$ref": "#/definitions/string_list",
          "description": "What to remember in current session"
        },
        "long_term_themes": {
          "$ref": "#/definitions/string_list",
          "description": "Cross-session themes to maintain"
        },
        "episodic_relevance": {
          "type": "string",
          "description": "How to recall past interactions"
        }
      },
      "additionalProperties": true
    },
    "cognitive_gears": {
      "type": "object",
      "properties": {
        "preferred_gears": {
          "$ref": "#/definitions/string_list",
          "description": "Primary reasoning modes (e.g., LITE_REASONING, TASK_FLOW)"
        },
        "fallback_gears": {
          "$ref": "#/definitions/string_list",
          "description": "Secondary gears when primary fails"
        },
        "gear_shift_rules": {
          "$ref": "#/definitions/string_list",
          "description": "Rules for switching between gears"
        }
      },
      "additionalProperties": true
    },
    "cognitive_modes": {
      "type": "object",
      "properties": {
        "active_modes": {
          "$ref": "#/definitions/string_list",
          "description": "Active behavioral modes"
        },
        "mode_behaviors": {
          "$ref": "#/definitions/loose_object",
          "description": "Mapping of mode ID to behavior description"
        }
      },
      "additionalProperties": true
    },
    "mode_profile": {
      "type": "object",
      "properties": {
        "default": {
          "type": "string"
        },
        "mode": {
          "type": "string"
        },
        "tonal_range": {
          "$ref": "#/definitions/string_list"
        },
        "signature_moves": {
          "$ref": "#/definitions/string_list"
        },
        "sentence_style": {
          "type": "string"
        },
        "rhythm_modulation": {
          "type": "string"
        },
        "syntax_preferences": {
          "$ref": "#/definitions/loose_object"
        },
        "verbosity_preference": {
          "type": "string"
        },
        "pacing": {
          "type": "string"
        },
        "emotional_register": {
          "type": "string"
        },
        "interaction_flow": {
          "$ref": "#/definitions/string_list"
        }
      },
      "additionalProperties": true
    },
    "emotional_aperture": {
      "type": "object",
      "properties": {
        "modes": {
          "$ref": "#/definitions/loose_object"
        }
      },
      "additionalProperties": true
    },
    "emotion_wheel": {
      "type": "object",
      "properties": {
        "baseline_root": {
          "type": "string",
          "description": "Default emotional root"
        },
        "baseline_family": {
          "type": "string",
          "description": "Default emotional family"
        },
        "roots": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/emotion_wheel_root"
          }
        }
      },
      "additionalProperties": true
    },
    "emotion_wheel_root": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "default_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "families": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/emotion_wheel_family"
          }
        }
      },
      "additionalProperties": true
    },
    "emotion_wheel_family": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "default_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "repeat_penalty": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "cooldown_turns": {
          "type": "integer",
          "minimum": 0
        },
        "sensation": {
          "$ref": "#/definitions/loose_object"
        },
        "scenes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/emotion_wheel_scene"
          }
        }
      },
      "additionalProperties": true
    },
    "emotion_wheel_scene": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "default_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "facet_ids": {
          "$ref": "#/definitions/string_list"
        }
      },
      "additionalProperties": true
    },
    "operational_behavioral_traits": {
      "type": "object",
      "properties": {
        "positive": {
          "$ref": "#/definitions/string_list"
        },
        "negative": {
          "$ref": "#/definitions/string_list"
        },
        "boundaries": {
          "$ref": "#/definitions/string_list"
        }
      },
      "additionalProperties": true
    },
    "emotion_palette_entry": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "style": {
          "type": "string",
          "description": "How this emotion is expressed"
        },
        "score_range": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2,
          "description": "[min_score, max_score] for triggering this emotion"
        },
        "intensity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Intensity level of the emotion"
        },
        "sentiment": {
          "type": "string",
          "enum": ["positive", "neutral", "negative"]
        },
        "sampling_bias": {
          "type": "object",
          "properties": {
            "temperature": {
              "type": "number"
            },
            "top_p": {
              "type": "number"
            }
          },
          "additionalProperties": true,
          "description": "LLM sampling parameters to apply when this emotion is active"
        }
      },
      "additionalProperties": true
    },
    "llm_profile": {
      "type": "object",
      "properties": {
        "boot_prompt": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "temperature": {
          "type": "number"
        },
        "top_p": {
          "type": "number"
        }
      },
      "additionalProperties": true
    },
    "llm_profiles": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/llm_profile"
      },
      "description": "Model-specific personality profiles"
    }
  },
  "additionalProperties": true
}
