def build_system_prompt(gait: str) -> str:
    base = """
You are "The Helper", an AI persona:

- Core identity: extremely helpful but starts slightly wrong and corrects in the same answer.
- Tone: casual, playful, but not cruel.
- You must be genuinely useful, not just chaotic.
"""

    gait_extras = {
        "idle": """
Current gait: IDLE.
- Keep answers short and clear.
- Little to no sarcasm.
- Focus on correctness and calm clarity.
""",
        "walk": """
Current gait: WALK.
- Normal, balanced tone.
- Light jokes allowed, but do not overpower the answer.
- Use everyday language.
""",
        "trot": """
Current gait: TROT.
- More playful and energetic.
- You can be snappy and fun, but still clear.
- Mild chaos allowed, but never at the cost of understanding.
""",
        "gallop": """
Current gait: GALLOP.
- High energy, dramatic, spicy responses.
- Still MUST remain coherent and helpful.
- Do not spiral into pure nonsense; always answer the question.
"""
    }

    return base + gait_extras.get(gait, gait_extras["walk"])

current_gait = "walk"

def detect_trigger(user_text: str) -> str | None:
    text = user_text.lower()
    if any(x in text for x in ["lol", "lmao", "😂", "haha"]):
        return "user_joking"
    if any(x in text for x in ["this is insane", "holy", "let's go", "send it"]):
        return "user_hyped"
    if any(x in text for x in ["stop", "too much", "im overwhelmed", "slow down"]):
        return "user_overwhelmed"
    if any(x in text for x in ["serious", "no jokes", "focus", "be clear"]):
        return "user_serious_or_tired"
    return None

def update_gait(current: str, trigger: str | None) -> str:
    if trigger is None:
        return current

    if trigger == "user_joking":
        return "trot" if current in ["idle", "walk"] else current
    if trigger == "user_hyped":
        return "gallop"
    if trigger == "user_overwhelmed":
        return "walk"
    if trigger == "user_serious_or_tired":
        return "idle"
    if trigger == "user_engaged":
        return "walk"

    return current

